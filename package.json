{
  "name": "pi-runtime-extensions",
  "version": "0.1.0",
  "description": "Dynamically load/unload extensions at runtime (inside session) for Pi Coding Agent with /ext:load, /ext:list, and /ext:unload commands.",
  "license": "Apache-2.0",
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "homepage": "https://github.com/tunnckoCore/pi-runtime-extensions",
  "repository": {
    "type": "git",
    "url": "https://github.com/tunnckoCore/pi-runtime-extensions.git"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "bunx tsgo-dev -p ./tsconfig.json",
    "test": "bun test",
    "cov": "bun test --coverage"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-coding-agent",
    "pi-extension",
    "runtime-extensions",
    "dynamic-extensions",
    "slash-commands",
    "agent-runtime",
    "llm",
    "ai"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  },
  "trustedDependencies": []
}
